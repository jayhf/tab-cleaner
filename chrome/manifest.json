{
  "manifest_version": 3,
  "name": "Tab Manager MCP",
  "version": "1.0.0",
  "description": "Chrome tab manager with MCP support for Claude",
  "permissions": ["tabs", "alarms", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Tab Manager"
  }
}
